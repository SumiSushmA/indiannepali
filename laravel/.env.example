# =============================================================================
# Indian Nepali Kitchen — environment template
# Copy to .env locally. On servers, create separate .env per environment:
#   • staging    — test before release (own DB, own APP_KEY, own URL)
#   • production — live site (never use staging DB or keys)
# =============================================================================

APP_NAME="Indian Nepali Kitchen"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Local: sqlite is fine. Staging/production: use MySQL or PostgreSQL ---
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=indiannepali
# DB_USERNAME=
# DB_PASSWORD=

# --- Local: file/session ok. Staging/production: database + queue worker ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Gmail SMTP (use an App Password — not your normal Gmail password) ---
# 1. Google Account → Security → turn on 2-Step Verification
# 2. Google Account → Security → App passwords → create "Mail" → copy 16-char password
# 3. Paste below. MAIL_USERNAME = full Gmail address.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Toast payments ---
# Empty = demo/mock checkout & gift cards (safe for local + staging).
# Fill all four core keys below to enable LIVE Toast on that environment.
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=
TOAST_MERCHANT_UUID=
TOAST_API_HOSTNAME=ws-api.toasttab.com
TOAST_CARD_ENCRYPTION_KEY=
TOAST_CARD_ENCRYPTION_KEY_ID=
TOAST_DINING_OPTION_DELIVERY_GUID=
TOAST_DINING_OPTION_PICKUP_GUID=
TOAST_REVENUE_CENTER_GUID=
TOAST_GIFT_CARD_MENU_ITEM_GUID=

# Toast hosted ordering (redirects /menu, /gift-cards, and gift card balance lookup to Toast)
TOAST_ONLINE_ORDERING_URL=https://order.toasttab.com/online/indian-nepali-kitchen-13754-aurora-ave-n-suite-d
TOAST_GIFT_CARDS_URL=https://order.toasttab.com/egiftcards/indian-nepali-kitchen-13754-aurora-ave-n-suite-d
TOAST_GIFT_CARD_BALANCE_URL=https://www.toasttab.com/indian-nepali-kitchen-13754-aurora-ave-n-suite-d/findcard
# Toast hosted catering (redirects /catering to Toast)
TOAST_CATERING_URL=https://tables.toasttab.com/restaurants/b2c622b2-577d-4081-b669-589978487fac/reserve?partySize=2&dateTime=2026-06-23T08:00:00.000-07:00

# =============================================================================
# STAGING (.env on staging server) — example values
# =============================================================================
# APP_ENV=staging
# APP_DEBUG=false
# APP_URL=https://staging.yourdomain.com
# APP_KEY=base64:...generate unique: php artisan key:generate...
# DB_CONNECTION=mysql
# DB_DATABASE=indiannepali_staging
# MAIL_MAILER=smtp
# MAIL_FROM_ADDRESS="staging@yourdomain.com"
# TOAST_* = leave empty for mock, OR use Toast sandbox if available
# SESSION_SECURE_COOKIE=true

# =============================================================================
# PRODUCTION (.env on live server) — example values
# =============================================================================
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://www.indiannepalikitchen.com
# APP_KEY=base64:...unique production key, never reuse staging...
# DB_CONNECTION=mysql
# DB_DATABASE=indiannepali_production
# MAIL_MAILER=smtp
# MAIL_FROM_ADDRESS="orders@indiannepalikitchen.com"
# TOAST_CLIENT_ID=... (live credentials from Toast)
# TOAST_CLIENT_SECRET=...
# TOAST_RESTAURANT_GUID=...
# TOAST_MERCHANT_UUID=...
# TOAST_CARD_ENCRYPTION_KEY=...
# TOAST_CARD_ENCRYPTION_KEY_ID=...
# TOAST_GIFT_CARD_MENU_ITEM_GUID=...
# SESSION_SECURE_COOKIE=true
# LOG_LEVEL=warning
